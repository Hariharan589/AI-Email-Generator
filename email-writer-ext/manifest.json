{
  "manifest_version": 3,
  "name": "AI Email Writer",
  "version": "1.0",

  "icons": {
    "128": "icon.png"
  },

  "permissions": [
    "activeTab"
  ],

  "host_permissions": [
    "http://localhost:8080/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ]
}